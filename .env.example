# ═══════════════════════════════════════════════════════════════════════════
# SYNDICATE AI — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ─── LLM Provider ───────────────────────────────────────────────────────────
# OpenAI-compatible endpoint. Supports: Anthropic, OpenAI, Ollama, Together AI
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=claude-opus-4-6
LLM_FALLBACK_MODEL=claude-sonnet-4-6

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=syndicate
POSTGRES_USER=syndicate
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://syndicate:change-me-in-production@postgres:5432/syndicate

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── API Authentication ──────────────────────────────────────────────────────
# Comma-separated list of valid API keys
SYNDICATE_API_KEYS=sk-dev-change-me,sk-test-change-me
API_KEY_HEADER_NAME=X-API-Key

# ─── Execution Limits ───────────────────────────────────────────────────────
MAX_STEPS_PER_WORKFLOW=100
DEFAULT_STEP_TIMEOUT_SECONDS=300
CELERY_WORKER_CONCURRENCY=4
MAX_RETRIES_DEFAULT=3

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ─── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                   # json | console
OTEL_SERVICE_NAME=syndicate-ai
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_ENABLED=true

# ─── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Environment ────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | staging | production
DEBUG=false
