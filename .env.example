# ═══════════════════════════════════════════════════════════════════════════════
# SYNDICATE AI — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# SETUP:
#   cp .env.example .env
#   Edit .env with your values
#   Never commit .env to version control (.gitignore already excludes it)
#
# SECURITY RULES:
#   - All "change-me" values MUST be replaced before any network exposure
#   - Use a secrets manager in production (Doppler / AWS Secrets Manager / Vault)
#   - Never share .env files over Slack, email, or any unencrypted channel
#   - Generate real keys: python3 -c "import secrets; print('sk-'+secrets.token_hex(32))"
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── LLM Provider ────────────────────────────────────────────────────────────
# OpenAI-compatible endpoint. Supports Anthropic, OpenAI, Ollama, Together AI.
#
# Anthropic:  LLM_BASE_URL=https://api.anthropic.com/v1
# OpenAI:     LLM_BASE_URL=https://api.openai.com/v1
# Ollama:     LLM_BASE_URL=http://localhost:11434/v1
# Together:   LLM_BASE_URL=https://api.together.xyz/v1

LLM_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=claude-opus-4-6
LLM_FALLBACK_MODEL=claude-sonnet-4-6

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# For Docker Compose: host = 'postgres' (service name)
# For production: use managed DB (AWS RDS / Cloud SQL / Supabase / Neon)

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=syndicate
POSTGRES_USER=syndicate
POSTGRES_PASSWORD=change-me-generate-strong-password
DATABASE_URL=postgresql+asyncpg://syndicate:change-me-generate-strong-password@postgres:5432/syndicate

# ─── Redis ───────────────────────────────────────────────────────────────────
# Redis 7+ required. AOF persistence is enabled in docker-compose.
# DB 0: memory store / cache   DB 1: Celery broker   DB 2: Celery results

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# With Redis AUTH (recommended for production):
# REDIS_URL=redis://:your-redis-password@redis:6379/0

# ─── API Authentication ───────────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# Generate: python3 -c "import secrets; print('sk-' + secrets.token_hex(32))"
# All API requests require header:  X-API-Key: <your-key>

SYNDICATE_API_KEYS=sk-change-me-generate-a-real-key
API_KEY_HEADER_NAME=X-API-Key

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# NEVER use * in production. List your actual frontend domains.

CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Execution Limits ────────────────────────────────────────────────────────
MAX_STEPS_PER_WORKFLOW=100
DEFAULT_STEP_TIMEOUT_SECONDS=300
CELERY_WORKER_CONCURRENCY=4
MAX_RETRIES_DEFAULT=3

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ─── Observability ────────────────────────────────────────────────────────────
# LOG_FORMAT: json (production) | console (development)

LOG_LEVEL=INFO
LOG_FORMAT=json
OTEL_SERVICE_NAME=syndicate-ai
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_ENABLED=true

# ─── File Paths ───────────────────────────────────────────────────────────────
AGENTS_DIR=agents
WORKFLOWS_DIR=workflows

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ─── Flower (Celery Monitor UI at :5555) ─────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-in-production

# ─── Grafana (Metrics dashboard at :3000) ────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-me-in-production

# ═══════════════════════════════════════════════════════════════════════════════
# QUICK START (local development)
# ═══════════════════════════════════════════════════════════════════════════════
#
#   1.  cp .env.example .env
#   2.  Set LLM_API_KEY to your real API key
#   3.  Generate and set SYNDICATE_API_KEYS (see above)
#   4.  docker compose up -d
#   5.  curl -H "X-API-Key: your-key" http://localhost:8000/health
#
# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════════
#
#   [ ] LLM_API_KEY  — production key, not dev key
#   [ ] POSTGRES_PASSWORD  — strong random password (32+ chars)
#   [ ] SYNDICATE_API_KEYS  — freshly generated, not the placeholder
#   [ ] CORS_ORIGINS  — your actual domains only, no wildcards
#   [ ] FLOWER_PASSWORD  — changed from default
#   [ ] GRAFANA_ADMIN_PASSWORD  — changed from default
#   [ ] DEBUG=false
#   [ ] ENVIRONMENT=production
#   [ ] LOG_FORMAT=json
#   [ ] Secrets loaded from secrets manager, not from .env file on disk
#
# ═══════════════════════════════════════════════════════════════════════════════
